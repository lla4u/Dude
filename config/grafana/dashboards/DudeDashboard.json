          "query": "data = from(bucket: \"dude\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"datalog\")\n  |> filter(fn: (r) => r[\"_field\"] == \"FuelRemaining\")\n\nmin = data\n  |> min()\n\nmax = data\n  |> max()\n\njoin(tables: {min: min, max: max}, on: [\"_start\", \"_field\", \"_start\", \"_measurement\"], method: \"inner\")\n  |> map(fn: (r) => ({ r with _value: r._value_max * 3.8 - r._value_min * 3.8 }))",
